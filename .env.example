# Agripals Environment Variables (example)
# Copy this to .env and fill in real values

# SMS provider (future)
SMS_API_KEY=your_sms_api_key_here

# Database (future)
DATABASE_URL=postgresql://user:password@localhost/agripals

# Discord webhook (for status updates)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Herbie / Honcho (if needed)
HERBIE_API_TOKEN=your_herbie_token_here
HONCHO_SERVER_URL=https://your.honcho.server
